rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isChildParent(childId) {
      return isAuth() &&
        request.auth.uid == get(/databases/$(database)/documents/children/$(childId)).data.parentUid;
    }

    // Parent accounts
    match /parents/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Children — parent owns, child device can update its own status
    match /children/{childId} {
      allow read: if isAuth() && (
        isChildParent(childId) ||
        request.auth.uid == resource.data.parentUid
      );
      allow create: if isAuth();
      allow update: if isAuth();  // parent or child device

      match /appLimits/{doc} {
        allow read: if isAuth();           // child reads its own limits
        allow write: if isChildParent(childId); // only parent sets limits
      }
      match /app_usage/{doc} {
        allow read: if isChildParent(childId);
        allow write: if isAuth();
      }
      match /geo_fences/{doc} {
        allow read, write: if isChildParent(childId);
      }
    }

    // Pairing codes — child reads before auth, parent creates
    match /pairing_codes/{code} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Time requests (camelCase collection name used in code)
    match /timeRequests/{requestId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.parentUid ||
        request.auth.uid == resource.data.childId
      );
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == resource.data.parentUid;
    }

    // Remote commands
    match /child_commands/{cmdId} {
      allow read, write: if isAuth();
    }

    // Alerts
    match /alerts/{alertId} {
      allow read: if isAuth() && request.auth.uid == resource.data.parentUid;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == resource.data.parentUid;
    }

    // SOS alerts
    match /sos_alerts/{alertId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }
  }
}
