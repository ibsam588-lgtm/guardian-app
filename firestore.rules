rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isChildParent(childId) {
      return isAuth() &&
        request.auth.uid == get(/databases/$(database)/documents/children/$(childId)).data.parentUid;
    }

    // ── Parent accounts ───────────────────────
    match /parents/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Children ──────────────────────────────
    match /children/{childId} {
      allow read, write: if isChildParent(childId);

      match /app_usage/{doc} {
        allow read: if isChildParent(childId);
        allow write: if isAuth(); // Child device writes
      }
      match /app_limits/{doc} {
        allow read: if isAuth();  // Child reads its own limits
        allow write: if isChildParent(childId); // Only parent writes limits
      }
      match /geo_fences/{doc} {
        allow read, write: if isChildParent(childId);
      }
      match /call_log/{doc} {
        allow read: if isChildParent(childId);
        allow write: if isAuth(); // Child writes
      }
      match /messages/{doc} {
        allow read: if isChildParent(childId);
        allow write: if isAuth();
      }
      match /web_history/{doc} {
        allow read: if isChildParent(childId);
        allow write: if isAuth();
      }
    }

    // ── Pairing codes ──────────────────────────
    match /pairing_codes/{code} {
      allow read: if true;  // Child reads before auth exists
      allow create: if isAuth();
      allow update: if isAuth(); // Child marks as used
    }

    // ── Time requests ──────────────────────────
    match /time_requests/{requestId} {
      // Parent reads their incoming requests
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.parentUid ||
         request.auth.uid == resource.data.childId);
      // Child creates request
      allow create: if isAuth();
      // Parent updates status (approve/deny)
      allow update: if isAuth() &&
        request.auth.uid == resource.data.parentUid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'respondedAt', 'grantedMinutes']);
    }

    // ── Remote commands ──────────────────────
    match /child_commands/{cmdId} {
      allow read: if isAuth(); // Child reads its commands
      allow create: if isAuth(); // Parent creates commands
      allow update: if isAuth(); // Child marks executed
    }

    // ── Alerts ────────────────────────────────
    match /alerts/{alertId} {
      allow read, write: if isAuth() &&
        request.auth.uid == resource.data.parentUid;
      allow create: if isAuth(); // System/child creates
    }
  }
}
